{
    "name": "oihana/php-ftp",
    "type": "library",
    "description": "The Oihana PHP FTP library - a modern, strongly-typed FTP/FTPS client",
    "keywords": [
        "php",
        "ftp",
        "ftps",
        "ftp-client",
        "file-transfer",
        "tls"
    ],
    "homepage": "https://github.com/BcommeBois/oihana-php-ftp",
    "license": [
        "MPL-2.0"
    ],
    "authors": [
        {
            "name": "Marc Alcaraz",
            "email": "marc@ooop.fr",
            "homepage": "https://www.ooop.fr",
            "role": "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\" : "tests"
        }
    },
    "autoload": {
        "psr-4": {
            "oihana\\ftp\\": "src/oihana/ftp"
        }
    },
    "require": {
        "php": ">=8.4",
        "ext-ftp": "*",
        "ext-openssl": "*",
        "oihana/php-core": "dev-main",
        "oihana/php-reflect": "dev-main",
        "oihana/php-enums": "dev-main",
        "oihana/php-logging": "dev-main",
        "oihana/php-files": "dev-main"
    },
    "suggest": {
        "ext-sodium": "Recommended for reliable in-memory credential wiping (sodium_memzero()). Without it, the library falls back to overwriting the buffer with NUL bytes.",
        "psr/log": "Inject a PSR-3 logger to trace connection, transfer and retry events."
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "doc": "rm -rf docs && mkdir docs && ./vendor/bin/phpdoc -c phpdoc.xml -v",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "coverage:md": [
            "@coverage",
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ],
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "nunomaduro/collision": "^8.8",
        "phpdocumentor/shim": "^3.8"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
